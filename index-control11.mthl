html(lang="ru")
	head
		title Учебник MDS · MarkDownStyle
		<!-- Bootstrap 5 + иконки Bootstrap Icons (легко читаемый светлый учебник) -->
		link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet")
		link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css")
		\\link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bulma@1.0.2/css/bulma.min.css")
		\\script(src="./lib/aMagic/mds/mds-bulma.js")
		<!-- чуть собственных штрихов для удобства чтения и имитации "учебного" стиля -->
		<style>
body {
	background: #f8fafc;
	font-family: 'Segoe UI', system-ui, -apple-system, BlinkMacSystemFont, Roboto, sans-serif;
	}
	.tutorial-header {
		background: linear-gradient(145deg, #1a9f18 0%, #0f50a1 100%);
		color: white;
		border-bottom: 5px solid #ffc107;
	}
	.tutorial-header h1 {
		font-weight: 500;
		letter-spacing: -0.02em;
	}
	.tutorial-header p {
		color: #cfdfee;
	}
details {
	border: 1px solid #ccc;
	border-radius: 4px;
	padding: 0.5rem 1rem;
	margin-bottom: 1rem;
	}
details[open] {
	background-color: #f8f9fa;
	}
details > summary {
	cursor: pointer;
	font-weight: 600;
	list-style: none;
	}
	
	

.card-tutorial {
	border: none;
	box-shadow: 0 8px 20px rgba(0,0,0,0.02), 0 2px 6px rgba(0,20,40,0.05);
	transition: all 0.1s ease;
	border-radius: 1.2rem;
	background-color: rgba(255,255,255,0.8);
	backdrop-filter: blur(2px);
	border: 1px solid rgba(0,0,0,0.03);
}
.card-tutorial:hover {
	box-shadow: 0 12px 28px rgba(0,32,64,0.08);
}
.section-tag {
	font-family: 'SF Mono', 'Fira Code', 'Cascadia Code', monospace;
	background: #e9ecef;
	padding: 0.2rem 0.8rem;
	border-radius: 3rem;
	font-size: 0.8rem;
	font-weight: 600;
	color: #1e3a5f;
	border: 1px solid #ced4da;
	display: inline-block;
	margin-bottom: 0.75rem;
}
pre {
	#background: #1e293b; /* тёмный блок под код – контрастно, отлично читается */
	color: #e2e8f0;
	padding: 1.2rem 1.5rem;
	border-radius: 1.2rem;
	font-size: 0.9rem;
	font-family: 'JetBrains Mono', 'Fira Code', monospace;
	border-left: 4px solid #f5b041;
	tab-size: 2;
	white-space: pre-wrap;
	word-break: break-word;
}

pre code {
	color: #0f20f1;
}

/*
pre code {
	color: #f1c40f;
}
*/
.markdown-hint {
	background: #f1f9fe;
	border-left: 5px solid #0d6efd;
	border-radius: 1rem 0.5rem 0.5rem 1rem;
	padding: 1.2rem 1.5rem;
	margin: 1.8rem 0;
}
.markdown-hint i {
	color: #0a58ca;
}
.markdown-hint2 {
	background: #fd00001f;
	border-left: 5px solid #fd0d0d;
	border-radius: 1rem 0.5rem 0.5rem 1rem;
	padding: 1.2rem 1.5rem;
	margin: 1.8rem 0;
}
.markdown-hint2 i {
	color: #c10000;
}

.badge-mds {
	background-color: #cfdfff;
	color: #012970;
	font-weight: 500;
	padding: 0.3rem 0.9rem;
	border-radius: 30px;
	font-size: 0.75rem;
	border: 1px solid #92b4e0;
}
.toc-sticky {
	position: sticky;
	top: 1.5rem;
	max-height: calc(100vh - 3rem);
	overflow-y: auto;
}
.list-group-toc a {
	border: none;
	padding: 0.5rem 1rem;
	background: transparent;
	color: #1e3a5f;
	font-weight: 450;
	border-radius: 40px;
}
.list-group-toc a:hover {
	background: #e5ecf5;
	color: #0b2a4f;
}
.list-group-toc a i {
	font-size: 0.75rem;
	margin-right: 0.4rem;
	color: #2c74b5;
}
hr.divider {
	opacity: 0.2;
	margin: 2.2rem 0;
}
.example-label {
	font-size: 0.85rem;
	display: block;
	margin-bottom: 0.2rem;
	color: #3f5e7a;
	letter-spacing: 0.3px;
}
		</style>
	

								label.form-label Тип тренировки:
								select#trainingType.form-select
									option(value="strength") Силовая (тяжелые подходы)
									option(value="volume") Объемная (средние веса)
									option(value="endurance") На выносливость (легкие веса)
							
							button.btn.btn-primary.w-100(type="submit")
								i.fas.fa-dumbbell.me-2 
								span Рассчитать рабочие веса

						#workingResult.mt-4(style="display: none;")
							.card.result-card
								.card-body
									h5.card-title Результаты расчета 
									p#resultText
									#weightTable
								
					<!-- Вкладка информации о формулах -->
					#info.tab-pane.fade(role="tabpanel" aria-labelledby="#info-tab")
						h4.mb-4 Формулы для расчета 1ПМ
						.row
							.col-md-6.mb-4
								.card.formula-card
									.card-header Формула Эпли
									.card-body
										p.card-text 1ПМ = Вес × (1 + 0.0333 × Повторения)
										p.text-muted Одна из самых популярных формул, хорошо работает для малого количества повторений.

							.col-md-6.mb-4
								div.card.formula-card
									div.card-header Формула Бжицки
									div.card-body
										p.card-text 1ПМ = Вес × (36 / (37 - Повторения))
										p.text-muted")Считается одной из самых точных формул, особенно для опытных атлетов.

							.col-md-6.mb-4
								div.card.formula-card
									div.card-header Формула Лэндера
									div.card-body
										p.card-text 1ПМ = (100 × Вес) / (101.3 - 2.67123 × Повторения)/p)
										p.text-muted Модификация формулы Эпли, считается более точной для большинства людей.

							.col-md-6.mb-4
								.card.formula-card
									div.card-header Формула Ватана
									div.card-body
										p.card-text 1ПМ = (100 × Вес) / (48.8 + 53.8 × e^(-0.075 × Повторения))
										p.text-muted Современная формула, учитывающая нелинейную зависимость между весом и повторениями.
									
						.alert.alert-info
							h5
								i.fas.fa-lightbulb.me-2 Совет
							p.mb-0 Для получения наиболее точных результатов рекомендуется использовать несколько формул и сравнивать результаты. Также помните, что формулы дают приблизительную оценку, и реальный 1ПМ может отличаться.
						
		footer
			p Калькулятор жима штанги лежа © 2025 | Создано с 
				<i class="fas fa-heart text-danger"></i> для атлетов

		<!-- Bootstrap 5 JS Bundle with Popper -->
		<!-- script async="" src="https://mc.yandex.ru/metrika/tag.js" style="display: none !important;"></script-->
		<script src="bootstrap.bundle.min.js"></script>
		
		<script>
       // Функция для анимированного изменения числа
function animateValue(element, start, end, duration) {
    let startTimestamp = null;
    const step = (timestamp) => {
        if (!startTimestamp) startTimestamp = timestamp;
        const progress = Math.min((timestamp - startTimestamp) / duration, 1);
        const value = Math.floor(progress * (end - start) + start);
        element.textContent = value + ' кг';
        
        if (progress < 1) {
            window.requestAnimationFrame(step);
        }
    };
    window.requestAnimationFrame(step);
}

// Формулы для расчета 1ПМ
const formulas = {
    epley: (weight, reps) => weight * (1 + reps / 30),
    brzycki: (weight, reps) => weight * (36 / (37 - reps)),
    lander: (weight, reps) => (100 * weight) / (101.3 - 2.67123 * reps),
    wathan: (weight, reps) => (100 * weight) / (48.8 + 53.8 * Math.exp(-0.075 * reps))
};

// Обработчик формы расчета 1ПМ
document.getElementById('oneRmCalculator').addEventListener('submit', function(e) {
    e.preventDefault();
    
    const weight = parseFloat(document.getElementById('weight').value);
    const reps = parseInt(document.getElementById('reps').value);
    
    if (isNaN(weight) || weight <= 0 || isNaN(reps) || reps <= 0 || reps > 12) {
        alert('Пожалуйста, введите корректные значения для веса и повторений');
        return;
    }
    
    const resultsContainer = document.getElementById('oneRmResultsContainer');
    resultsContainer.innerHTML = '';
    
    let hasResults = false;
    
    // Проверяем каждую формулу и добавляем результат, если выбран чекбокс
    for (const [key, formula] of Object.entries(formulas)) {
        if (document.getElementById(key).checked) {
            const oneRm = Math.round(formula(weight, reps));
            
            const formulaNames = {
                epley: 'Эпли',
                brzycki: 'Бжицки',
                lander: 'Лэндера',
                wathan: 'Ватана'
            };
            
            const col = document.createElement('div');
            col.className = 'col-md-6 mb-3';
            col.innerHTML = `
                <div class="card formula-card">
                    <div class="card-body text-center">
                        <h5 class="card-title">${formulaNames[key]}</h5>
                        <div class="display-4 text-primary fw-bold one-rm-value">0 кг</div>
                        <p class="text-muted">Ваш расчетный 1ПМ</p>
                    </div>
                </div>
            `;
            
            resultsContainer.appendChild(col);
            
            // Анимируем изменение числа
            const valueElement = col.querySelector('.one-rm-value');
            setTimeout(() => {
                animateValue(valueElement, 0, oneRm, 1000);
            }, 100);
            
            hasResults = true;
        }
    }
    
    if (hasResults) {
        document.getElementById('oneRmResult').style.display = 'block';
    } else {
        alert('Пожалуйста, выберите хотя бы одну формулу для расчета');
    }
});

// Обработчик формы расчета рабочих весов
document.getElementById('workingWeightCalculator').addEventListener('submit', function(e) {
    e.preventDefault();
    
    const oneRepMax = parseFloat(document.getElementById('oneRepMax').value);
    const reps = document.querySelector('input[name="reps"]:checked').value;
    const trainingType = document.getElementById('trainingType').value;
    
    if (isNaN(oneRepMax) || oneRepMax <= 0) {
        alert('Пожалуйста, введите корректное значение для одноповторного максимума');
        return;
    }
    
    // Рассчитываем вес для выбранного количества повторений
    let weightForReps;
    switch(reps) {
        case '3':
            weightForReps = oneRepMax * 0.93;
            break;
        case '5':
            weightForReps = oneRepMax * 0.87;
            break;
        case '8':
            weightForReps = oneRepMax * 0.80;
            break;
        case '10':
            weightForReps = oneRepMax * 0.75;
            break;
        default:
            weightForReps = oneRepMax * 0.87;
    }
    
    // Рассчитываем веса для разных подходов в зависимости от типа тренировки
    let setsWeights = [];
    let trainingDescription = '';
    
    switch(trainingType) {
        case 'strength':
            setsWeights = [
                { sets: 1, reps: reps, percentage: 100, weight: Math.round(weightForReps) },
                { sets: 2, reps: reps, percentage: 95, weight: Math.round(weightForReps * 0.95) },
                { sets: 1, reps: reps, percentage: 90, weight: Math.round(weightForReps * 0.90) }
            ];
            trainingDescription = 'Силовая тренировка: тяжелые подходы с небольшим снижением веса для поддержания интенсивности.';
            break;
            
        case 'volume':
            setsWeights = [
                { sets: 1, reps: reps, percentage: 100, weight: Math.round(weightForReps) },
                { sets: 3, reps: reps, percentage: 100, weight: Math.round(weightForReps) },
                { sets: 1, reps: reps, percentage: 90, weight: Math.round(weightForReps * 0.90) }
            ];
            trainingDescription = 'Объемная тренировка: несколько подходов с одинаковым весом для наработки объема.';
            break;
            
        case 'endurance':
            const enduranceReps = parseInt(reps) + 2;
            const enduranceWeight = Math.round(weightForReps * 0.85);
            setsWeights = [
                { sets: 1, reps: enduranceReps, percentage: 85, weight: enduranceWeight },
                { sets: 3, reps: enduranceReps, percentage: 85, weight: enduranceWeight },
                { sets: 1, reps: enduranceReps, percentage: 80, weight: Math.round(enduranceWeight * 0.94) }
            ];
            trainingDescription = 'Тренировка на выносливость: увеличение количества повторений с меньшим весом.';
            break;
    }
    
    // Формируем текст результата с анимацией
    const roundedWeight = Math.round(weightForReps);
    let resultText = `При вашем одноповторном максимуме ${oneRepMax} кг, для ${reps} повторений рекомендуется вес: <strong><span id="animatedWeight">0</span></strong>.`;
    resultText += `<br>${trainingDescription}`;
    
    // Формируем таблицу с подходами
    let weightTable = `
        <table class="table table-hover mt-3">
            <thead class="table-primary">
                <tr>
                    <th>Подходы</th>
                    <th>Повторения</th>
                    <th>% от 1ПМ</th>
                    <th>Вес (кг)</th>
                </tr>
            </thead>
            <tbody>
    `;
    
    setsWeights.forEach((set, index) => {
        weightTable += `
            <tr>
                <td>${set.sets}</td>
                <td>${set.reps}</td>
                <td>${set.percentage}%</td>
                <td><span class="badge bg-primary weight-badge animated-set-weight" data-weight="${set.weight}">0 кг</span></td>
            </tr>
        `;
    });
    
    weightTable += `</tbody></table>`;
    
    // Отображаем результат
    document.getElementById('resultText').innerHTML = resultText;
    document.getElementById('weightTable').innerHTML = weightTable;
    document.getElementById('workingResult').style.display = 'block';
    
    // Анимируем основной вес
    setTimeout(() => {
        const weightElement = document.getElementById('animatedWeight');
        animateValue(weightElement, 0, roundedWeight, 800);
    }, 100);
    
    // Анимируем веса в таблице с задержкой
    setTimeout(() => {
        const setWeightElements = document.querySelectorAll('.animated-set-weight');
        setWeightElements.forEach((element, index) => {
            const finalWeight = parseInt(element.getAttribute('data-weight'));
            setTimeout(() => {
                animateValue(element, 0, finalWeight, 600);
            }, index * 200); // Задержка для каждого следующего элемента
        });
    }, 500);
    
    // Прокручиваем к результату
    document.getElementById('workingResult').scrollIntoView({ behavior: 'smooth' });
});
		</script>